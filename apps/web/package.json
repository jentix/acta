{
  "name": "@acta-dev/web",
  "version": "0.1.1",
  "description": "Prebuilt Astro viewer for Acta docs-as-code repositories, built on demand by `acta site`",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jentix/acta.git",
    "directory": "apps/web"
  },
  "homepage": "https://github.com/jentix/acta#readme",
  "keywords": [
    "acta",
    "adr",
    "docs-as-code",
    "astro",
    "viewer"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "public",
    "astro.config.mjs",
    "tsconfig.json"
  ],
  "exports": {
    "./package.json": "./package.json"
  },
  "scripts": {
    "artifacts": "node scripts/build-artifacts.mjs",
    "dev": "node scripts/build-artifacts.mjs && ASTRO_TELEMETRY_DISABLED=1 astro dev --host 127.0.0.1",
    "build": "node scripts/build-artifacts.mjs && ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "test": "vitest run",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check"
  },
  "dependencies": {
    "@acta-dev/core": "workspace:*",
    "@acta-dev/renderer": "workspace:*",
    "@astrojs/react": "^5.0.5",
    "@dagrejs/dagre": "^3.0.0",
    "@orama/orama": "^3.1.18",
    "@xyflow/react": "^12.10.2",
    "astro": "^6.3.7",
    "i18next": "^26.2.0",
    "i18next-resources-to-backend": "^1.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
