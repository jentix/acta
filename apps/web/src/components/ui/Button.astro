---
type ButtonVariant = "primary" | "secondary" | "ghost";
type ButtonSize = "sm" | "md";

interface Props {
  variant?: ButtonVariant;
  size?: ButtonSize;
  as?: "a" | "button";
  href?: string;
  type?: "button" | "submit" | "reset";
  hidden?: boolean;
  class?: string;
  [key: `data-${string}`]: string | number | boolean | undefined;
}

const {
  variant = "secondary",
  size = "md",
  as = "button",
  href,
  type = "button",
  class: className,
  ...rest
} = Astro.props as Props & Record<string, unknown>;

const classes = ["ui-button", `ui-button--${variant}`, `ui-button--${size}`, className]
  .filter(Boolean)
  .join(" ");
---

{
  as === "a" ? (
    <a class={classes} href={href} {...rest}>
      <slot />
    </a>
  ) : (
    <button class={classes} type={type} {...rest}>
      <slot />
    </button>
  )
}

<style>
  .ui-button[hidden] {
    display: none;
  }

  .ui-button {
    display: inline-flex;
    flex: none;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3-5);
    border: 1px solid var(--color-text);
    border-radius: 0;
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.12s, color 0.12s;
  }

  .ui-button:hover {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .ui-button--sm {
    padding: var(--space-1-5) var(--space-3);
    font-size: 10px;
  }

  .ui-button--primary {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-accent-ink);
  }

  .ui-button--primary:hover {
    background: color-mix(in srgb, var(--color-accent) 85%, var(--color-text));
    color: var(--color-accent-ink);
  }

  .ui-button--ghost {
    border-color: transparent;
  }

  .ui-button--ghost:hover {
    background: transparent;
    color: var(--color-accent);
  }
</style>
