---
type PillTone = "neutral" | "success" | "danger" | "warning";

interface Props {
  as?: "a" | "span";
  href?: string;
  tone?: PillTone;
  class?: string;
  [key: `data-${string}`]: string | number | boolean | undefined;
}

const {
  as = "span",
  href,
  tone = "neutral",
  class: className,
  ...rest
} = Astro.props as Props & Record<string, unknown>;

const classes = ["ui-pill", `ui-pill--${tone}`, className].filter(Boolean).join(" ");
---

{
  as === "a" ? (
    <a class={classes} href={href} {...rest}>
      <slot />
    </a>
  ) : (
    <span class={classes} {...rest}>
      <slot />
    </span>
  )
}

<style>
  .ui-pill {
    display: inline-flex;
    flex: none;
    align-items: center;
    gap: var(--space-2);
    padding: 0;
    background: transparent;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .ui-pill::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
  }

  .ui-pill--success {
    color: var(--status-active-fg);
  }

  .ui-pill--danger {
    color: var(--color-danger);
  }

  .ui-pill--warning {
    color: var(--color-warning);
  }
</style>
