---
interface Option {
  value: string;
  label: string;
}

interface Props {
  name: string;
  legend: string;
  options: Option[];
  value?: string;
  dataAttr?: string;
  class?: string;
}

const { name, legend, options, value, dataAttr, class: className } = Astro.props;
const classes = ["ui-segmented", className].filter(Boolean).join(" ");
const dataProps: Record<string, string> = dataAttr ? { [dataAttr]: "" } : {};
---

<fieldset class={classes} aria-label={legend}>
  <legend>{legend}</legend>
  {
    options.map((option) => (
      <label>
        <input
          type="radio"
          name={name}
          value={option.value}
          checked={value ? value === option.value : undefined}
          {...dataProps}
        />
        <span>{option.label}</span>
      </label>
    ))
  }
</fieldset>

<style>
  .ui-segmented {
    display: flex;
    align-self: end;
    gap: 0;
    margin: 0;
    padding: 0;
    border: 1px solid var(--color-text);
  }

  .ui-segmented legend {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .ui-segmented label {
    display: inline-flex;
  }

  .ui-segmented input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .ui-segmented span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2) var(--space-3);
    background: transparent;
    color: var(--color-text);
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 500;
    line-height: 1;
    cursor: pointer;
    box-sizing: border-box;
    transition:
      background var(--duration-hover) var(--ease-out),
      color var(--duration-hover) var(--ease-out);
  }

  .ui-segmented label:active span {
    transform: scale(0.97);
  }

  .ui-segmented input:checked + span {
    background: var(--color-text);
    color: var(--color-bg);
  }

  .ui-segmented input:focus-visible + span {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }
</style>
