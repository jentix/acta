---
interface Option {
  value: string;
  label: string;
}

interface Props {
  name: string;
  legend: string;
  options: Option[];
  value?: string;
  dataAttr?: string;
  class?: string;
}

const { name, legend, options, value, dataAttr, class: className } = Astro.props;
const classes = ["ui-segmented", className].filter(Boolean).join(" ");
const dataProps: Record<string, string> = dataAttr ? { [dataAttr]: "" } : {};
---

<fieldset class={classes} aria-label={legend}>
  <legend>{legend}</legend>
  {
    options.map((option) => (
      <label>
        <input
          type="radio"
          name={name}
          value={option.value}
          checked={value ? value === option.value : undefined}
          {...dataProps}
        />
        <span>{option.label}</span>
      </label>
    ))
  }
</fieldset>

<style>
  .ui-segmented {
    display: flex;
    align-items: end;
    gap: var(--space-1);
    min-width: 260px;
    margin: 0;
    padding: 0;
    border: 0;
  }

  .ui-segmented legend {
    width: 100%;
    margin-bottom: 5px;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
  }

  .ui-segmented label {
    display: inline-flex;
    flex: 1;
  }

  .ui-segmented input {
    position: absolute;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  .ui-segmented span {
    display: inline-flex;
    width: 100%;
    height: 34px;
    align-items: center;
    justify-content: center;
    padding: 0 var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-panel);
    color: var(--color-text-muted);
    font-size: var(--text-base);
    box-sizing: border-box;
    line-height: 1;
  }

  .ui-segmented input:checked + span {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .ui-segmented input:focus-visible + span {
    outline: 2px solid var(--color-accent);
    outline-offset: 1px;
  }

  @media (max-width: 860px) {
    .ui-segmented {
      min-width: 0;
    }
  }
</style>
