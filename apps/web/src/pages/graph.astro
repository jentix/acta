---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildDocumentHref, collectFilterOptions } from "@lib/documents.js";
import { loadActaWebData } from "@lib/project.js";
import DocumentGraphIsland from "../components/graph/DocumentGraphIsland.tsx";

const { project } = await loadActaWebData();
const documents = project.documents;
const filterOptions = collectFilterOptions(documents);
const hrefForId = Object.fromEntries(documents.map((d) => [d.id, buildDocumentHref(d.id)]));
---

<BaseLayout title="Acta graph" description="Explore Acta document relationships">
  <section class="page-header">
    <div>
      <p class="eyebrow">Repository viewer</p>
      <h1>Graph</h1>
      <p class="muted">
        {project.graph.nodes.length} nodes, {project.graph.edges.length} relationships
      </p>
    </div>
  </section>

  <DocumentGraphIsland
    client:load
    graph={project.graph}
    filterOptions={filterOptions}
    hrefForId={hrefForId}
  />
</BaseLayout>
