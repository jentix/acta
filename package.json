{
  "name": "acta",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "engines": {
    "node": ">=22.12 <26"
  },
  "scripts": {
    "build": "turbo run build",
    "build:web": "pnpm --filter @acta-dev/web build",
    "dev": "concurrently -n core,renderer,cli,web -c blue,magenta,cyan,green \"pnpm --filter @acta-dev/core dev\" \"pnpm --filter @acta-dev/renderer dev\" \"pnpm --filter @acta-dev/cli dev\" \"pnpm --filter @acta-dev/web dev\"",
    "dev:web": "pnpm --filter @acta-dev/web dev",
    "test": "turbo run test",
    "lint": "biome lint .",
    "format:check": "biome format .",
    "typecheck": "turbo run typecheck",
    "gen:skill": "tsx scripts/gen-skill.mts",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@acta-dev/cli": "workspace:*",
    "@acta-dev/core": "workspace:*",
    "@biomejs/biome": "2.4.15",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^22.15.3",
    "concurrently": "^9.2.1",
    "lefthook": "^2.1.8",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "turbo": "^2.9.14",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
