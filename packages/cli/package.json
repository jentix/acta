{
  "name": "@acta-dev/cli",
  "version": "1.2.0",
  "description": "Acta CLI — TypeScript-first docs-as-code tooling for ADR and spec documents in Git. Provides the `acta` binary.",
  "keywords": [
    "adr",
    "spec",
    "docs-as-code",
    "architecture-decision-records",
    "cli",
    "documentation",
    "markdown"
  ],
  "license": "MIT",
  "author": "jentix",
  "homepage": "https://github.com/jentix/acta#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jentix/acta.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/jentix/acta/issues"
  },
  "type": "module",
  "bin": {
    "acta": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12 <26"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@acta-dev/core": "workspace:*",
    "@acta-dev/web": "workspace:*",
    "citty": "^0.2.2",
    "kleur": "^4.1.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "execa": "^9.6.1",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
