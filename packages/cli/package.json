{
  "name": "@acta/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "acta": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@acta/core": "workspace:*",
    "citty": "^0.2.2",
    "kleur": "^4.1.5",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "execa": "^9.6.1",
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
