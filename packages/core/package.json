{
  "name": "@acta-dev/core",
  "version": "1.2.0",
  "description": "Acta core — canonical document pipeline (schema, parser, validator, graph, search index, artifacts) for ADR and spec docs-as-code.",
  "keywords": [
    "adr",
    "spec",
    "docs-as-code",
    "architecture-decision-records",
    "documentation",
    "markdown",
    "zod"
  ],
  "license": "MIT",
  "author": "jentix",
  "homepage": "https://github.com/jentix/acta#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jentix/acta.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/jentix/acta/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22.12 <26"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts src/config.ts src/search.ts --format esm --dts",
    "dev": "tsup src/index.ts src/config.ts src/search.ts --format esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
