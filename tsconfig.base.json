{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@adr-book/core": ["packages/core/src/index.ts"],
      "@adr-book/renderer": ["packages/renderer/src/index.ts"]
    },
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "outDir": "dist"
  }
}
